# ============================================================
# HelloPay Neural Backend – Production Environment
# ============================================================
# Copy this file to .env and fill in the values below.
# NEVER commit the actual .env file to version control.

# --- Server ---
PORT=5000
NODE_ENV=production

# --- Database ---
# Replace with your MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/Hello_pay?retryWrites=true&w=majority

# --- Auth ---
# Replace with a long, random secret (min 32 chars)
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET_KEY_HERE

# --- Payment Gateway (Razorpay) ---
RAZORPAY_KEY_ID=rzp_live_your_key_id
RAZORPAY_KEY_SECRET=your_live_key_secret

# --- CORS ---
# Add deployed frontend URLs separated by commas
ALLOWED_ORIGINS=https://hellopay-admin.vercel.app,https://hellopay-web.vercel.app
